{
  "compilerOptions": {
    "allowSyntheticDefaultImports": true,
    "rootDir": ".",
    "outDir": "dist",
    "checkJs": false,
    "declaration": false,
    "experimentalDecorators": true,
    "moduleResolution": "bundler",
    "lib": ["ES2017"],
    "types": ["node"],
    "module": "commonjs",
    "sourceMap": false,
    "skipLibCheck": true,
    "target": "ES2015",
  },
  "include": ["index.ts"],
}
